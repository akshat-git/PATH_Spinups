Bootstrap: docker
From: pytorch/pytorch:2.1.0-cuda11.8-cudnn8-runtime

%post
    apt-get update && apt-get install -y git && apt-get clean
    pip install --no-cache-dir transformers timm huggingface_hub
    pip install --no-cache-dir git+https://github.com/paige-ai/Virchow.git

%environment
    export PYTHONUNBUFFERED=1
